{
  "name": "bamboo-digital-project-management-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --watch prisma --ext ts,tsx,js,jsx,css,prisma --exec \"next dev\" --signal SIGTERM",
    "build": "next build",
    "start": "node start.js",
    "start:prod": "NODE_ENV=production node start.js",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.21",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "nodemon": "^3.1.14",
    "prebuild-install": "^7.1.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
