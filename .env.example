# Bamboo Digital Project Management Tracker - Environment Configuration
# For Dev Environments, copy this file to .env.local and fill in your values
# For Production, Enter these values in your hosting environment i.e Plesk Custom Env Vars in Node.js Settings

# Next.js dev server port
PORT=3010

# Prisma Database URL (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Admin credentials used by seed script and update-password script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here
